class NarcolepticSuperhero(object):



	@property
	def choose_asleep(self):
		return True


	@property
	def choose_hanging_out(self):
		return False


	states = ['asleep' ,'hanging_out' ,'hungry' ,'sweaty' ,'saving_the_world']
	transitions = [
	               ['distress_call', ['asleep' ,'hanging_out' ,'hungry' ,'sweaty' ,'saving_the_world'] , 'saving_the_world']
	               , ['complete_mission', 'saving_the_world', 'sweaty']
	               , ['wake_up', 'asleep', 'hanging_out']
