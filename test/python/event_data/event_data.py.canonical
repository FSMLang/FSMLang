from transitions import Machine

class MyMachine(object):

	states = [	          'idle'
	           ,'running'
	           ,'stopped'
	          ]
	transitions = [
	               {'trigger': 'launch'
	                 , 'source': 'idle'
	                 , 'dest': 'running'
	                 , 'before': 'do_launch'
	                 , 'prepare': 'translate_launch_data'
	                 }
	               , {'trigger': 'halt'
	                 , 'source': 'running'
	                 , 'dest': 'stopped'
	                 , 'before': 'do_halt'
	                 , 'prepare': 'translate_halt_data'
	                 }
	               , ['reset', 'stopped', 'idle']
	               ]

	def __init__(self):
		self.machine = Machine(model=self, states=MyMachine.states, transitions=MyMachine.transitions, initial='idle', send_event=True)
		self.data = {}


	def do_launch(self):
		print('do_launch')


	def do_halt(self):
		print('do_halt')


