from transitions import Machine

class MachineData(object):



	def data_init(self):
		self.count = 0


	states = ['idle' ,'active']
	transitions = [
	               ['activate', 'idle', 'active']
	               , ['deactivate', 'active', 'idle']
	               ]

	def __init__(self):
		self.machine = Machine(model=self, states=MachineData.states, transitions=MachineData.transitions, initial='idle')
		self.data_init()

