machine NarcolepticSuperhero
{
	state asleep, hanging_out, hungry, sweaty, saving_the_world;

	event wake_up, work_out, eat, distress_call, complete_mission, clean_up, nap;

	action change_into_super_secret_costume[distress_call,(all)] transition saving_the_world;
	action update_journal[complete_mission, saving_the_world] transition sweaty;
	transition [wake_up, asleep] hanging_out;
	transition [work_out, hanging_out] hungry;
	transition [eat, hungry] hanging_out;
	transition [clean_up, sweaty] decide_rest;
	decide_rest returns asleep when is_exhausted, hanging_out otherwise;

}

