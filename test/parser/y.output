Grammar

    0 $accept: fsmlang $end

    1 fsmlang: machine
    2        | fsmlang machine

    3 machine_prefix: native machine_modifier MACHINE_KEY

    4 $@1: ε

    5 machine: machine_prefix ID machine_qualifier $@1 '{' statement_decl_list '}'

    6 machine_qualifier: ε
    7                  | machine_transition_decl
    8                  | action_return_spec
    9                  | native_impl
   10                  | machine_qualifier machine_transition_decl
   11                  | machine_qualifier action_return_spec
   12                  | machine_qualifier native_impl

   13 machine_transition_decl: ON TRANSITION_KEY ID ';'

   14 action_return_spec: ACTIONS RETURN EVENTS ';'
   15                   | ACTIONS RETURN STATES ';'
   16                   | ACTIONS RETURN VOID ';'

   17 machine_modifier: ε
   18                 | REENTRANT

   19 statement_decl_list: state_and_event_decls actions_and_transitions
   20                    | machine_data state_and_event_decls actions_and_transitions
   21                    | statement_decl_list sequences

   22 sequence_start: SEQUENCE_KEY
   23               | sequence_start ID
   24               | sequence_start ID START_KEY STATE
   25               | sequence_start START_KEY STATE

   26 sequence_node: EVENT
   27              | EVENT TRANSITION_KEY STATE

   28 sequence_nodes: sequence_node
   29               | sequence_nodes ',' sequence_node

   30 sequence: sequence_start sequence_nodes ';'
   31         | sequence_start sequence_nodes END_KEY STATE ';'

   32 sequences: sequence
   33          | sequences sequence

   34 machine_list: machine
   35             | machine_list machine

   36 actions_and_transitions: machine_list
   37                        | action_decl
   38                        | transition_matrix_list
   39                        | action_return_decl
   40                        | transition_fn_return_decl
   41                        | actions_and_transitions action_decl
   42                        | actions_and_transitions transition_matrix_list
   43                        | actions_and_transitions action_return_decl
   44                        | actions_and_transitions transition_fn_return_decl

   45 transition_matrix_list: transition_matrix

   46 transition_matrix_start: matrix TRANSITION_KEY
   47                        | TRANSITION_KEY matrix

   48 guard_matrix_start: matrix GUARD_KEY
   49                   | GUARD_KEY matrix

   50 transition_matrix: transition_matrix_start STATE ';'
   51                  | transition_matrix_start ID ';'
   52                  | transition_matrix_start TRANSITION_FN ';'
   53                  | guard_matrix_start ID ';'
   54                  | guard_matrix_start TRANSITION_FN ';'

   55 action_decl: action_decl_list ';'

   56 action_decl_list: ACTION_KEY action
   57                 | action_decl_list ',' action

   58 action: action_matrix
   59       | action_matrix transition

   60 transition: TRANSITION_KEY STATE
   61           | TRANSITION_KEY ID
   62           | TRANSITION_KEY TRANSITION_FN
   63           | GUARD_KEY ID
   64           | GUARD_KEY TRANSITION_FN

   65 action_matrix: ID matrix
   66              | ACTION matrix

   67 matrix: '[' event_vector ',' state_vector ']'

   68 state_vector: '(' ALL ')'
   69             | '(' state_comma_list STATE ')'
   70             | STATE

   71 state_comma_list: STATE ','
   72                 | state_comma_list STATE ','

   73 event_vector: '(' ALL ')'
   74             | '(' event_comma_list EVENT ')'
   75             | EVENT

   76 event_comma_list: EVENT ','
   77                 | event_comma_list EVENT ','

   78 state_and_event_decls: state_decl
   79                      | event_decl
   80                      | state_and_event_decls state_decl
   81                      | state_and_event_decls event_decl

   82 state_decl: state_decl_list ';'

   83 state: ID
   84      | state INHIBITS SUBMACHINES
   85      | state ON ENTRY
   86      | state ON ENTRY ID
   87      | state ON EXIT
   88      | state ON EXIT ID

   89 state_decl_list: STATE_KEY state
   90                | state_decl_list ',' state

   91 event_decl: event_decl_list ';'

   92 parent_namespace: PARENT NAMESPACE

   93 user_event_data: ε
   94                | DATA_KEY TRANSLATOR_KEY ID
   95                | DATA_KEY TRANSLATOR_KEY ID data_block
   96                | DATA_KEY data_block

   97 event_decl_list: EVENT_KEY ID external_designation user_event_data
   98                | EVENT_KEY parent_namespace EVENT user_event_data
   99                | event_decl_list ',' ID external_designation user_event_data
  100                | event_decl_list ',' parent_namespace EVENT user_event_data

  101 external_designation: ε
  102                     | '=' ID

  103 native: ε
  104       | native native_prologue
  105       | native native_epilogue

  106 native_prologue: NATIVE_KEY NATIVE_BLOCK
  107                | NATIVE_KEY PROLOGUE_KEY NATIVE_BLOCK

  108 native_epilogue: NATIVE_KEY EPILOGUE_KEY NATIVE_BLOCK

  109 native_impl: native_impl_prologue
  110            | native_impl_epilogue
  111            | native_impl native_impl_prologue
  112            | native_impl native_impl_epilogue

  113 native_impl_prologue: NATIVE_KEY IMPLEMENTATION_KEY NATIVE_BLOCK
  114                     | NATIVE_KEY IMPLEMENTATION_KEY PROLOGUE_KEY NATIVE_BLOCK

  115 native_impl_epilogue: NATIVE_KEY IMPLEMENTATION_KEY EPILOGUE_KEY NATIVE_BLOCK

  116 machine_data: DATA_KEY data_block

  117 data_block: '{' data_fields '}'

  118 data_fields: data_field
  119            | data_fields data_field

  120 data_type: ID
  121          | TYPE_NAME
  122          | STRUCT_KEY '{' data_fields '}'
  123          | UNION_KEY '{' data_fields '}'
  124          | data_type '*'

  125 data_field: data_type ID data_field_dimension ';'
  126           | data_type ID ';'

  127 data_field_dimension: '[' ']'
  128                     | '[' NUMERIC_STRING ']'
  129                     | '[' ID ']'

  130 namespace: parent_namespace
  131          | MACHINE NAMESPACE

  132 namespace_event_ref: namespace EVENT

  133 returns_comma_list: namespace_event_ref ','
  134                   | EVENT ','
  135                   | returns_comma_list namespace_event_ref ','
  136                   | returns_comma_list EVENT ','

  137 action_return_decl: ACTION RETURNS returns_comma_list EVENT ';'
  138                   | ACTION RETURNS returns_comma_list namespace_event_ref ';'
  139                   | ACTION RETURNS EVENT ';'
  140                   | ACTION RETURNS namespace_event_ref ';'
  141                   | ACTION RETURNS state_comma_list STATE ';'
  142                   | ACTION RETURNS STATE ';'

  143 transition_fn_return_decl: TRANSITION_FN RETURNS state_comma_list STATE ';'
  144                          | TRANSITION_FN RETURNS STATE ';'
  145                          | TRANSITION_FN RETURNS return_choice_cond_list return_choice_cond ';'
  146                          | TRANSITION_FN RETURNS return_choice_cond ';'

  147 return_choice_cond_list: return_choice_cond ','
  148                        | return_choice_cond_list return_choice_cond ','

  149 return_choice_cond: STATE WHEN_KEY ID
  150                   | STATE WHEN_KEY TRANSITION_FN
  151                   | STATE OTHERWISE_KEY


