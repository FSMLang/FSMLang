native
{
#include "test.h"
}

machine test_fsm
	actions return void;
	native impl
   {
	#define INIT_FSM_DATA { .e1_count = 0 }
	}
{
	data
	{
		int e1_count;
	}

	event e1 data translator grab_e1_data {int i;};
	event e2, e3;

	state s1
         on entry enter_s1
         , s2
           on exit leave_s2
         ;

	action act_on_e1[e1, (s1, s2)];

	action act_on_e2[e2, s1] transition s2;
	action act_on_e3[e3, s2] guard      guard1;

}

