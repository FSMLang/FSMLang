}

machine test_fsm
	data translators return events;
	actions return void;
	on transition record;
	native impl
	{
	#define INIT_FSM_DATA { .e1_count = 0 }
	}
{
	data
	{
		int e1_count;
	}

	event e1 data translator grab_e1 {int ext_event; int i;};
	event e2;

	state s1, s2;

	include sub.fsms

	include sub2.fsms

	action act_on_e1[e1, s1] transition s2;
	action act_on_e1[e1, s2] transition s1;

}

