native
{
#include "test.h"
}

/**
	This machine is a great test machine for various
	esoteric reasons.
*/
machine test_fsm
	actions return events;
	/**
		This simply records from and to states.
	*/
	on transition record;
	native impl
	{
	#define INIT_FSM_DATA0 { .e1_count = 0 }
	#define INIT_FSM_DATA1 { .e1_count = 100 }
	#define INIT_FSM_DATA2 { .e1_count = 1000 }
	}
{
	data
	{
		int e1_count;
	}

	/** e1 is our very first event. */
	event e1 
	  data
		 /**
          Grab e1 data.
       */
       translator grab_e1_data
       {int i;}
       ;

	/** Our solitary state. */
	state s1
     /**
       Set up things for being in s1.
     */
     on entry enter_s1
     /**
        Tidy-up on leaving s1.
     */
     on exit  exit_s1
     ;

	/**
		This is a great sub machine.
	*/
	machine sub
		actions return events;
		native impl
		{
		#define INIT_FSM_DATA0 { .sub_e1_count = 0 }
		#define INIT_FSM_DATA1 { .sub_e1_count = 100 }
		#define INIT_FSM_DATA2 { .sub_e1_count = 1000 }
		}
	{
		data
		{
			int sub_e1_count;
		}

		/** e1 is our very first event; but, we're sharing it from our parent. */
		event parent::e1
        data
          /**
            Grab the parent data before handling parent::e1.
          */
          translator grab_parent_e1_data
        ;

		/** Our solitary state. */
		state s1;

		/**
			This machine is just here to prove we can nest two deep.
		*/
		machine subSub
			actions return events;
			native impl
			{
			#define INIT_FSM_DATA0 { .subSub_e1_count = 0 }
			#define INIT_FSM_DATA1 { .subSub_e1_count = 100 }
			#define INIT_FSM_DATA2 { .subSub_e1_count = 1000 }
			}
		{
			data
			{
				int subSub_e1_count;
			}
	
			/** e1 is our very first event; but, we're sharing it from our parent. */
			event parent::e1
           data
             /**
               Grab the parent data before handling parent::e1.
             */
             translator grab_parent_e1_data
           ;

			/** Our solitary state. */
			state s1;
	
			action 
      	/**
        	 Really, do nothing.
      	*/
			do_nothing[e1, s1];
		}

		action 
      /**
         Really, do nothing.
      */
		do_nothing[e1, s1];
	}

	/**
		This is another really great sub machine.

		We need two paragraphs in this comment.
	*/
	machine sub2
		actions return events;
		native impl
		{
		#define INIT_FSM_DATA0 { .sub2_e1_count = 0 }
		#define INIT_FSM_DATA1 { .sub2_e1_count = 100 }
		#define INIT_FSM_DATA2 { .sub2_e1_count = 1000 }
		}
	{
		data
		{
			int sub2_e1_count;
		}

		/** e1 is our very first event; but, we're sharing it from our parent. */
		event parent::e1
        data
          /**
            Grab the parent data before handling parent::e1.
          */
          translator grab_parent_e1_data
          ;

		/** Our solitary state. */
		state s1;

		machine subSub
			actions return events;
			native impl
			{
			#define INIT_FSM_DATA0 { .subSub_e1_count = 0 }
			#define INIT_FSM_DATA1 { .subSub_e1_count = 100 }
			#define INIT_FSM_DATA2 { .subSub_e1_count = 1000 }
			}
		{
			data
			{
				int subSub_e1_count;
			}
	
			/** e1 is our very first event; but, we're sharing it from our parent. */
			event parent::e1
          /**
            Grab the parent data before handling parent::e1.
          */
          data translator grab_parent_e1_data;

			/** Our solitary state. */
			state s1;
	
			action do_nothing[e1, s1];
		}

		action do_nothing[e1, s1];
	}

	/**
		This is a really important matrix.
	*/
	action 
   	/**
     	 Do cool things with e1.
   	*/
		handle_e1[e1, s1];

}

