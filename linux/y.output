Grammar

    0 $accept: fsmlang $end

    1 fsmlang: machine
    2        | fsmlang machine

    3 machine_prefix: native machine_modifier MACHINE_KEY

    4 $@1: ε

    5 machine: machine_prefix ID machine_qualifier $@1 '{' statement_decl_list '}'

    6 machine_qualifier: ε
    7                  | machine_transition_decl
    8                  | action_return_spec
    9                  | native_impl
   10                  | machine_qualifier machine_transition_decl
   11                  | machine_qualifier action_return_spec
   12                  | machine_qualifier native_impl

   13 machine_transition_decl: ON TRANSITION_KEY ID ';'

   14 action_return_spec: ACTIONS RETURN EVENTS ';'
   15                   | ACTIONS RETURN STATES ';'
   16                   | ACTIONS RETURN VOID ';'

   17 machine_modifier: ε
   18                 | REENTRANT

   19 statement_decl_list: state_and_event_decls actions_and_transitions
   20                    | machine_data state_and_event_decls actions_and_transitions
   21                    | statement_decl_list sequences

   22 sequence_start: SEQUENCE_KEY
   23               | sequence_start ID
   24               | sequence_start ID START_KEY STATE
   25               | sequence_start START_KEY STATE

   26 sequence_node: EVENT
   27              | EVENT TRANSITION_KEY STATE

   28 sequence_nodes: sequence_node
   29               | sequence_nodes ',' sequence_node

   30 sequence: sequence_start sequence_nodes ';'
   31         | sequence_start sequence_nodes END_KEY STATE ';'

   32 sequences: sequence
   33          | sequences sequence

   34 machine_list: machine
   35             | machine_list machine

   36 actions_and_transitions: machine_list
   37                        | action_decl
   38                        | transition_matrix_list
   39                        | action_return_decl
   40                        | transition_fn_return_decl
   41                        | actions_and_transitions action_decl
   42                        | actions_and_transitions transition_matrix_list
   43                        | actions_and_transitions action_return_decl
   44                        | actions_and_transitions transition_fn_return_decl

   45 transition_matrix_list: transition_matrix

   46 transition_matrix_start: matrix TRANSITION_KEY
   47                        | TRANSITION_KEY matrix
   48                        | matrix GUARD_KEY
   49                        | GUARD_KEY matrix

   50 transition_matrix: transition_matrix_start STATE ';'
   51                  | transition_matrix_start ID ';'
   52                  | transition_matrix_start TRANSITION_FN ';'

   53 action_decl: action_decl_list ';'

   54 action_decl_list: ACTION_KEY action
   55                 | action_decl_list ',' action

   56 action: action_matrix
   57       | action_matrix transition

   58 transition: TRANSITION_KEY STATE
   59           | TRANSITION_KEY ID
   60           | TRANSITION_KEY TRANSITION_FN
   61           | GUARD_KEY ID
   62           | GUARD_KEY TRANSITION_FN

   63 action_matrix: ID matrix
   64              | ACTION matrix

   65 matrix: '[' event_vector ',' state_vector ']'

   66 state_vector: '(' ALL ')'
   67             | '(' state_comma_list STATE ')'
   68             | STATE

   69 state_comma_list: STATE ','
   70                 | state_comma_list STATE ','

   71 event_vector: '(' ALL ')'
   72             | '(' event_comma_list EVENT ')'
   73             | EVENT

   74 event_comma_list: EVENT ','
   75                 | event_comma_list EVENT ','

   76 state_and_event_decls: state_decl
   77                      | event_decl
   78                      | state_and_event_decls state_decl
   79                      | state_and_event_decls event_decl

   80 state_decl: state_decl_list ';'

   81 state: ID
   82      | state INHIBITS SUBMACHINES
   83      | state ON ENTRY
   84      | state ON ENTRY ID
   85      | state ON EXIT
   86      | state ON EXIT ID

   87 state_decl_list: STATE_KEY state
   88                | state_decl_list ',' state

   89 event_decl: event_decl_list ';'

   90 parent_namespace: PARENT NAMESPACE

   91 user_event_data: ε
   92                | DATA_KEY TRANSLATOR_KEY ID
   93                | DATA_KEY TRANSLATOR_KEY ID data_block
   94                | DATA_KEY data_block

   95 event_decl_list: EVENT_KEY ID external_designation user_event_data
   96                | EVENT_KEY parent_namespace EVENT user_event_data
   97                | event_decl_list ',' ID external_designation user_event_data
   98                | event_decl_list ',' parent_namespace EVENT user_event_data

   99 external_designation: ε
  100                     | '=' ID

  101 native: ε
  102       | native native_prologue
  103       | native native_epilogue

  104 native_prologue: NATIVE_KEY NATIVE_BLOCK
  105                | NATIVE_KEY PROLOGUE_KEY NATIVE_BLOCK

  106 native_epilogue: NATIVE_KEY EPILOGUE_KEY NATIVE_BLOCK

  107 native_impl: native_impl_prologue
  108            | native_impl_epilogue
  109            | native_impl native_impl_prologue
  110            | native_impl native_impl_epilogue

  111 native_impl_prologue: NATIVE_KEY IMPLEMENTATION_KEY NATIVE_BLOCK
  112                     | NATIVE_KEY IMPLEMENTATION_KEY PROLOGUE_KEY NATIVE_BLOCK

  113 native_impl_epilogue: NATIVE_KEY IMPLEMENTATION_KEY EPILOGUE_KEY NATIVE_BLOCK

  114 machine_data: DATA_KEY data_block

  115 data_block: '{' data_fields '}'

  116 data_fields: data_field
  117            | data_fields data_field

  118 data_type: ID
  119          | TYPE_NAME
  120          | STRUCT_KEY '{' data_fields '}'
  121          | UNION_KEY '{' data_fields '}'
  122          | data_type '*'

  123 data_field: data_type ID data_field_dimension ';'
  124           | data_type ID ';'

  125 data_field_dimension: '[' ']'
  126                     | '[' NUMERIC_STRING ']'
  127                     | '[' ID ']'

  128 namespace: parent_namespace
  129          | MACHINE NAMESPACE

  130 namespace_event_ref: namespace EVENT

  131 returns_comma_list: namespace_event_ref ','
  132                   | EVENT ','
  133                   | returns_comma_list namespace_event_ref ','
  134                   | returns_comma_list EVENT ','

  135 action_return_decl: ACTION RETURNS returns_comma_list EVENT ';'
  136                   | ACTION RETURNS returns_comma_list namespace_event_ref ';'
  137                   | ACTION RETURNS EVENT ';'
  138                   | ACTION RETURNS namespace_event_ref ';'
  139                   | ACTION RETURNS state_comma_list STATE ';'
  140                   | ACTION RETURNS STATE ';'

  141 transition_fn_return_decl: TRANSITION_FN RETURNS state_comma_list STATE ';'
  142                          | TRANSITION_FN RETURNS STATE ';'


